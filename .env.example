# En deploy Docker avec Prefect
MLFLOW_S3_ENDPOINT_URL=http://minio:9000  # Le nom du conteneur MinIO dans ton réseau Docker
MLFLOW_TRACKING_URI=http://mlflow_server:5000 # Le nom du conteneur MLflow dans ton réseau Docker
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
PREFECT_API_URL=http://localhost:4200/api
POSTGRES_PASSWORD=un_mot_de_passe_robuste

# Paramètres du modèle
MODEL_NAME=iris_model
MODEL_ALIAS=production